{
  "name": "doccas",
  "version": "1.0.0",
  "description": "Editable SVG + DOM product-factory canvas for Markdown documents",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3200",
    "build": "next build",
    "start": "next start -p 3200",
    "test": "tsx --test tests/**/*.test.ts",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:update": "npm run build && playwright test --update-snapshots",
    "test:e2e:prepare": "tsx scripts/prepare-standalone-e2e.ts",
    "test:e2e:serve": "npm run test:e2e:prepare && node .next/standalone/server.js",
    "pilot:unlock-pack": "tsx scripts/enrichment-pilot-unlock-pack.ts",
    "pilot:authorization-request": "tsx scripts/enrichment-pilot-authorization-request.ts",
    "typecheck": "tsc --noEmit --pretty false",
    "verify:local": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "gray-matter": "^4.0.3",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.400.0",
    "next": "15.5.21",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "sharp": "0.35.3",
    "tailwind-merge": "^2.5.0",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "8.5.10",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "postcss": "$postcss",
    "sharp": "$sharp"
  }
}
