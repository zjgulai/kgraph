{
  "name": "doccas",
  "version": "1.0.0",
  "description": "Interactive infinite canvas for your Playbook documents — React Flow-powered knowledge graph",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3200",
    "build": "next build",
    "start": "next start -p 3200",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit --pretty false",
    "verify:local": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@xyflow/react": "^12.0.0",
    "clsx": "^2.1.0",
    "gray-matter": "^4.0.3",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.400.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "tailwind-merge": "^2.5.0",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "8.5.10",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
